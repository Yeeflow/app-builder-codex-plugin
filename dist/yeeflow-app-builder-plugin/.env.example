YEEFLOW_WORKSPACE_ID=<your workspace id>

# Optional only if tenant UI/browser links are needed.
YEEFLOW_TENANT_URL=https://<yourdomain>.yeeflow.com

# Temporary/private until PKCE/no-secret token exchange is supported.
# Keep this in .env.local only. Do not commit real values.
# YEEFLOW_OAUTH_CLIENT_SECRET=<your local OAuth client secret>

# Plugin defaults, override only for development/testing:
# YEEFLOW_API_BASE_URL=https://api.yeeflow.com/v1
# YEEFLOW_OAUTH_CLIENT_ID=266479ba-1f82-463b-856d-9a50b6166e0d
# YEEFLOW_OAUTH_AUTH_URL=https://login.yeeflow.com/connect/authorize
# YEEFLOW_OAUTH_TOKEN_URL=https://login.yeeflow.com/connect/token
# YEEFLOW_OAUTH_SCOPES="basic_api openid offline_access"

# Legacy/deprecated API-key fallback. OAuth is preferred for normal API calls.
# YEEFLOW_API_KEY=<your Yeeflow API key>
# YEEFLOW_TENANT_ID=<optional tenant id>

# Optional local HTTPS callback certificate paths for browser OAuth login.
# Defaults point to ignored local files under .yeeflow-oauth/.
# YEEFLOW_OAUTH_CALLBACK_CERT_FILE=.yeeflow-oauth/localhost-cert.pem
# YEEFLOW_OAUTH_CALLBACK_KEY_FILE=.yeeflow-oauth/localhost-key.pem

# Required for package import/install/upgrade automation.
# Keep workspace IDs local in .env.local. Do not commit .env.local.

# Optional profile mode
# YEEFLOW_PROFILE=dev
# YEEFLOW_DEV_TENANT_URL=https://<devdomain>.yeeflow.com
# YEEFLOW_DEV_TENANT_ID=<optional>
# YEEFLOW_DEV_WORKSPACE_ID=<dev workspace id>
# YEEFLOW_DEV_API_KEY=<legacy dev API key>
# YEEFLOW_PROD_TENANT_URL=https://<proddomain>.yeeflow.com
# YEEFLOW_PROD_TENANT_ID=<optional>
# YEEFLOW_PROD_WORKSPACE_ID=<prod workspace id>
# YEEFLOW_PROD_API_KEY=<legacy prod API key>
# YEEFLOW_TEST_TENANT_URL=https://<testdomain>.yeeflow.com
# YEEFLOW_TEST_TENANT_ID=<optional>
# YEEFLOW_TEST_WORKSPACE_ID=<test workspace id>
# YEEFLOW_TEST_API_KEY=<legacy test API key>
# YEEFLOW_CLIENT_A_TENANT_URL=https://<client-a-domain>.yeeflow.com
# YEEFLOW_CLIENT_A_TENANT_ID=<optional>
# YEEFLOW_CLIENT_A_WORKSPACE_ID=<client A workspace id>
# YEEFLOW_CLIENT_A_API_KEY=<legacy client A API key>
