      "id": "assignment_assignee_job_position",
      "sourceNodes": [
        "Finance manager approval",
        "Casher confirm",
        "General manager approval"
      ],
      "description": "Assign the task to a resolved Yeeflow Job Position.",
      "generationPolicy": "Use only a discovered existing, user-selected existing, or admin-created-after-confirmation Job Position ID. Expired OAuth must be refreshed and read-only positions lookup must be attempted before fallback. Do not reuse sample export IDs and do not invent IDs.",
      "creationPolicy": "Admin-created positions require confirmed admin permission, explicit user approval, one accepted POST /positions response with numeric ID recorded, bounded read-back polling without retrying create, duplicate-name scan, and optional current-user assignment via POST /positions/{id}/users using UserIDs.",
      "unresolvedPolicy": "If no suitable Job Position can be proven or created with explicit admin confirmation after OAuth recovery and API lookup, leave the position unresolved and let generated-final preflight block signing.",
      "usertaskassignment": [
        {
          "type": "position",
          "method": "position",
          "position": "<CONFIRMED_JOB_POSITION_ID>",
          "titleShape": "Job position: <CONFIRMED_JOB_POSITION_NAME>",
          "requiredProofFields": [
            "requiredJobPositionName",
            "source",
            "proofStatus",
            "oauthStatus",
            "jobPositionLookupStatus"
          ],
          "adminCreatedRequiredProofFields": [
            "creationConfirmed",
            "systemAdminConfirmed",
            "jobPositionCreateAttemptCount",
            "jobPositionCreateResponseIdRecorded",
            "duplicateNameScanRecorded"
          ]
        }
      ]
    },
