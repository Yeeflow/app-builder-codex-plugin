    "rootContainerCw": "2",
    "rootPadding": "zero-token-array",
    "hiddenFormNameCss": true,
    "mainContentRequired": true,
    "contentCustomWidth": 1280
  },
  "allowedBusinessContentContainers": [
    "page_title_content",
    "Operations",
    "section_content_area",
    "section_title_header"
  ],
  "allowedRepeatableRemovableModules": [
    "1_columns_section",
    "content_card_wrapper",
    "2_columns_section",
    "3_columns_section",
    "2_columns_60/40_section",
    "content_card_60_wrapper",
    "content_card_40_wrapper"
  ],
  "lockedContainers": [
    "action_panel_flow_history_wrapper"
  ],
  "forbiddenComponentFamilies": [
    "Data Analytics templates",
    "KPI metrics wrapper",
    "Dashboard page root shells copied as competing roots"
  ],
  "templates": [
    {
      "templateId": "approval_form_layout_submission_v1_1",
      "displayName": "Submission form page layout",
      "sourceTemplate": "docs/reference/approval-form-layout-submission.template.json",
      "requiredForPageTypes": [
        "submission"
      ],
      "forbiddenForPageTypes": [
        "task"
      ],
      "role": "Approval submission form",
      "requiredTemplateRegions": [
        "main",
        "content",
        "page_title_section",
        "page_title_content",
        "page_title_text",
        "page_title_description",
        "1_columns_section",
        "content_card_wrapper",
        "section_title_area",
        "section_title_header",
        "section_content_area",
        "action_panel_flow_history_wrapper"
      ],
      "allowedComponentFamilies": [
        "approval form field controls",
        "approved Data List Form field grid template",
        "approved Collection templates except data analytics",
        "Text/Heading controls",
        "configured action buttons in Operations",
        "workflow action panel",
        "workflow history"
      ],
      "appPlanUse": "Select this template for the single submission form in every generated Approval form."
    },
    {
      "templateId": "approval_form_layout_task_v1_1",
      "displayName": "Task form page layout",
      "sourceTemplate": "docs/reference/approval-form-layout-task.template.json",
      "requiredForPageTypes": [
        "task"
      ],
      "forbiddenForPageTypes": [
        "submission"
      ],
      "role": "Approval task form",
      "requiredTemplateRegions": [
        "main",
        "content",
        "page_title_section",
        "page_title_content",
        "page_title_text",
        "page_title_description",
        "1_columns_section",
        "content_card_wrapper",
        "section_title_area",
        "section_title_header",
        "section_content_area",
        "action_panel_flow_history_wrapper"
      ],
      "allowedComponentFamilies": [
        "read-only approval context fields by default",
        "approval task decision fields when required",
        "approved Data List Form field grid template",
        "approved Collection templates except data analytics",
        "Text/Heading controls",
        "configured action buttons in Operations",
        "workflow action panel",
        "workflow history"
      ],
      "appPlanUse": "Select this template for every generated approval task form. Task fields should be read-only unless the business task requires assignee input."
    }
