{
  "schemaVersion": 1,
  "registryId": "approval-form-layouts-v1.1",
  "defaultVersion": "approval-form-layouts-v1.1",
  "description": "Approved page-level golden reference templates for generated Yeeflow Approval form submission and task forms. These templates align Approval forms with Dashboard Page Layouts v1.1 and Data List Form Layouts v1.1 while preserving Approval-specific action panel and workflow history controls.",
  "sourceExport": "Approval form page layout.ywf",
  "sourceApprovalFormName": "Approval form page layout",
  "approvedTemplateIds": [
    "approval_form_layout_submission_v1_1",
    "approval_form_layout_task_v1_1"
  ],
  "requiredRoot": {
