{
  "topic": "yeeflow-application-delivery-workflow",
  "rule": "oauth-and-workspace-selection-delivery-decision",
  "envPresenceOnly": true,
  "variables": [
    "oauthToken",
    "selectedFlowcraftWorkspace",
    "optionalYEEFLOW_WORKSPACE_ID"
  ],
  "decisions": [
    {
      "condition": "OAuth missing",
      "nextStep": "ask current user to run OAuth login"
    },
    {
      "condition": "OAuth present and target workspace missing",
      "nextStep": "generate YAPK for manual install"
    },
    {
      "condition": "OAuth present and target workspace selected",
      "nextStep": "ask user whether to auto-install"
    }
  ]
}
