            },
            "required": [
              "FieldName"
            ]
          },
          "then": {
            "properties": {
              "IsSystem": {
                "const": true
              },
              "FieldIndex": {
                "const": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Text"
              }
            },
            "required": [
