                "minimum": 1
              },
              "FieldName": {
                "type": "string",
                "pattern": "^(Text|Bit|Decimal|Datetime)[1-9]\\d*$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": true
              }
            },
            "required": [
              "IsSystem"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "const": 0
              },
              "FieldName": {
                "const": "Title"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "FieldName": {
                "const": "Title"
