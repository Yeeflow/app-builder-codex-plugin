          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 300
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Bit"
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 50
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Decimal"
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 200
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Datetime"
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 200
              }
            }
          }
        }
      ],
      "x-rules": {
        "CustomFieldNameFormat": "If IsSystem=false then FieldName must be {FieldType}{FieldIndex}.",
        "CustomFieldNameExactMatch": "For custom fields, FieldName must exactly equal FieldType + FieldIndex.",
        "SystemFieldOnlyTitle": "If IsSystem=true then FieldName must be Title and FieldIndex must be 0.",
