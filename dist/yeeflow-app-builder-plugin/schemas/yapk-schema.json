{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akmii.local/schemas/listset-package-info.schema.json",
  "title": "AppExportPackageInfo",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "PackageId",
    "TenantID",
    "AppID",
    "ListID",
    "Title",
    "Description",
    "IconUrl",
    "Resource",
    "Notes",
    "Author",
    "Date",
    "Version",
    "Sign"
  ],
  "properties": {
    "PackageId": {
      "type": "string",
      "minLength": 1
    },
    "TenantID": {
      "$ref": "#/$defs/LongAsString"
    },
    "AppID": {
      "type": "integer",
      "enum": [
        30,
        41
      ],
      "x-enumNames": [
        "Settings",
        "Flowcraft"
      ]
    },
    "ListID": {
      "$ref": "#/$defs/LongAsString"
    },
    "Title": {
      "type": "string"
    },
    "Description": {
      "type": "string"
    },
    "IconUrl": {
      "type": "string"
    },
    "Resource": {
      "type": "string",
      "description": "Convert.ToBase64String(Brotli compressed) string. Decompressed JSON should match #/$defs/AppPackageInfo"
    },
    "Notes": {
      "type": "string"
    },
    "Author": {
      "type": "string"
    },
    "Date": {
      "type": "string",
      "description": "UTC time in yyyy-MM-ddTHH:mm:ssZ"
    },
    "Version": {
      "type": "string"
    },
    "Sign": {
      "type": "string"
    }
  },
  "$defs": {
    "LongAsString": {
      "type": "string",
      "pattern": "^-?\\d+$"
    },
    "JsonString": {
      "type": "string",
      "description": "JSON serialized string field"
    },
    "AnyObject": {
      "type": "object",
      "additionalProperties": true
    },
