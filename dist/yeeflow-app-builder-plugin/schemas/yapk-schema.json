              "FieldType"
            ]
          },
          "then": {
            "x-valueLengthRange": {
              "min": 1,
              "max": 300
            }
          }
        },
        {
          "if": {
            "properties": {
              "FieldType": {
                "const": "Bit"
              }
            },
            "required": [
              "FieldType"
            ]
          },
          "then": {
            "x-valueLengthRange": {
              "min": 1,
              "max": 50
            }
          }
        },
        {
          "if": {
            "properties": {
              "FieldType": {
                "const": "Decimal"
