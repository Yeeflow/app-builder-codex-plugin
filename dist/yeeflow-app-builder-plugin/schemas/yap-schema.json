{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yap-v1-schema.json",
  "title": "YAP v1 Template Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "Title",
    "Description",
    "IconUrl",
    "IsListSet",
    "Resource"
  ],
  "properties": {
    "Title": {
      "type": "string"
    },
    "Description": {
      "type": "string"
    },
    "IconUrl": {
      "type": "string"
    },
    "IsListSet": {
      "type": "boolean"
    },
    "Resource": {
      "type": "string",
      "pattern": "^\\[______gizp______\\].+",
      "description": "Fixed prefix [______gizp______] + Gzip(UTF8 JSON(ListExportResult))"
    }
  },
  "x-decodedResourceSchema": {
    "$ref": "#/$defs/ListExportResult"
  },
