          "type": "integer"
        },
        "ListID": {
          "type": "integer"
        },
        "FieldName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": ".*\\d+$"
        },
        "FieldType": {
          "type": "string",
          "enum": [
            "Text",
            "Bit",
            "Decimal",
            "Datetime"
          ]
        },
        "FieldIndex": {
