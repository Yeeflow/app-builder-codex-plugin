          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[a-zA-Z0-9_]+$"
        },
        "Type": {
          "type": "string",
          "enum": [
            "input",
            "textarea",
            "richtext",
            "hyperlink",
            "input_number",
            "currency",
            "percent",
            "calculated-column",
            "rate",
            "switch",
            "checkbox",
            "radio",
            "select",
            "tag",
            "datepicker",
            "time",
            "identity-picker",
            "organization-picker",
            "cost-center-picker",
            "signer",
            "file-upload",
            "icon-upload",
            "lookup",
            "mutiple-metadata",
            "location-picker",
            "flowstatus",
            "autonumber",
            "list"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "FieldType": {
                "const": "Text"
              }
            },
            "required": [
              "FieldType"
            ]
          },
          "then": {
            "x-valueLengthRange": {
              "min": 1,
              "max": 300
            }
          }
        },
        {
          "if": {
            "properties": {
              "FieldType": {
                "const": "Bit"
              }
            },
            "required": [
              "FieldType"
            ]
          },
          "then": {
            "x-valueLengthRange": {
              "min": 1,
              "max": 50
            }
          }
        },
        {
          "if": {
            "properties": {
              "FieldType": {
                "const": "Decimal"
              }
            },
            "required": [
              "FieldType"
            ]
          },
          "then": {
            "x-valueLengthRange": {
              "min": 1,
              "max": 200
            }
          }
        },
        {
          "if": {
            "properties": {
              "FieldType": {
                "const": "Datetime"
              }
            },
            "required": [
              "FieldType"
            ]
          },
          "then": {
            "x-valueLengthRange": {
              "min": 1,
              "max": 200
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex",
              "FieldName"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1
              },
              "FieldName": {
                "type": "string",
                "pattern": "^(Text|Bit|Decimal|Datetime)[1-9]\\d*$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": true
              }
            },
            "required": [
              "IsSystem"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "const": 0
              },
              "FieldName": {
                "const": "Title"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "FieldName": {
                "const": "Title"
              }
            },
            "required": [
              "FieldName"
            ]
          },
          "then": {
            "properties": {
              "IsSystem": {
                "const": true
              },
              "FieldIndex": {
                "const": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Text"
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 300
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Bit"
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 50
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Decimal"
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 200
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "IsSystem": {
                "const": false
              },
              "FieldType": {
                "const": "Datetime"
              }
            },
            "required": [
              "IsSystem",
              "FieldType",
              "FieldIndex"
            ]
          },
          "then": {
            "properties": {
              "FieldIndex": {
                "type": "integer",
                "minimum": 1,
                "maximum": 200
              }
            }
          }
        }
      ],
      "x-rules": {
        "CustomFieldNameFormat": "If IsSystem=false then FieldName must be {FieldType}{FieldIndex}.",
        "CustomFieldNameExactMatch": "For custom fields, FieldName must exactly equal FieldType + FieldIndex.",
        "SystemFieldOnlyTitle": "If IsSystem=true then FieldName must be Title and FieldIndex must be 0.",
        "TitleImpliesSystemField": "If FieldName=Title then IsSystem must be true and FieldIndex must be 0.",
        "FieldIndexStartsFromOneForCustom": "If IsSystem=false then FieldIndex starts from 1.",
        "FieldIndexUpperBoundByFieldType": "For custom fields, FieldIndex max depends on FieldType (see x-fieldIndexRangeByFieldType)."
