  "reusableControlPatterns": {
    "nav_menu_item_container": {
      "controlType": "container",
      "direction": "row",
      "gap": 6,
      "align_items": "center",
      "padding": {
        "top": 8,
        "right": 10,
        "bottom": 8,
        "left": 10
      },
      "borderRadius": 6,
      "hoverBackground": "#ffffff",
      "children": [
        "inline_icon_or_user_control",
        "heading_text_control"
      ],
      "action": "form action sets filter variables"
    },
    "ticket_collection_item_container": {
      "controlType": "container",
      "direction": "row",
      "padding": {
        "top": 12,
        "right": 12,
        "bottom": 12,
        "left": 6
      },
      "borderRadius": 12,
      "normalBackground": "rgba(7, 22, 56, 0.05)",
      "hoverBackground": "rgba(7, 22, 56, 0.06)",
      "selectedState": "style rule compares current-ticket variable to collection item id",
      "action": "click action sets current-ticket variable from collection item id"
    },
    "detail_field_row_container": {
      "controlType": "container",
      "direction": "row",
      "gap": 5,
      "align_items": "center",
      "justify_content": "space-between",
      "padding": 6,
      "children": [
        "label heading",
        "dynamic-field or dynamic-user"
      ]
    },
    "long_detail_field_container": {
      "controlType": "container",
      "direction": "column",
      "gap": 5,
      "align_items": "flex-start",
      "justify_content": "flex-start",
      "padding": 6
    },
    "comment_update_bar": {
      "controlType": "container",
      "direction": "row",
      "marginTop": "auto",
      "bottom": "0px",
      "topBorder": true,
      "shadow": "subtle top shadow",
      "children": [
        "dynamic-user",
        "richtext",
        "identity-picker",
        "file-upload-merge",
        "action_button"
      ]
    },
    "icon_control": {
      "controlType": "icon",
      "common.positioning.widthtype": "2",
      "typicalSizes": [
        13,
        14,
        18
      ],
      "generationRule": "Use inline width and bounded size; never allow full-width/block icons inside narrow panels."
    }
  },
  "actionAndStatePatterns": {
    "filterVariables": [
      "current view",
      "current role",
      "current mobile view",
      "priority filter",
      "status filter",
      "search visibility",
      "hide navigation panel",
      "hide details panel",
      "current ticket item"
    ],
    "navAction": "menu container click executes set-variable steps and refresh/display rules",
    "collectionFilter": "collection data/filter references form variables and current user context",
    "selectedRecord": "ticket item click stores collection item id into current-ticket variable",
    "detailBinding": "selected workspace and attributes panel use dynamic-field/dynamic-user controls bound through selected/current-ticket state",
    "collapseExpand": "icon or icon container actions toggle panel visibility variables"
  },
  "brokenSmokeFailurePattern": {
    "symptom": "visible content squeezed into narrow vertical text columns",
    "likelyCause": "generic/default containers lacked explicit width, height, row direction, overflow, align-items, justify-content, gap, and bounded icon/text width behavior",
    "validatorImplication": "a package claiming multi_column_form_workspace_shell must fail before signing/install if these runtime layout properties are absent"
  }
