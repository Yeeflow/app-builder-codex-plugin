# Normal OAuth + workspace discovery does not require `.env.local`.
# The file may be absent or empty.

# Login before API access:
# node scripts/yeeflow-oauth-login.mjs

# Workspace discovery uses OAuth and documented categories:
# node scripts/yeeflow-workspace-list.mjs --all
# node scripts/yeeflow-workspace-list.mjs --category flowcraft

# For app package install/import/upgrade workflows, use the flowcraft category
# to choose a workspace, then pass the selected target with --workspace-id or
# another local-only manual override. Do not commit workspace IDs.

# Optional local HTTPS callback certificate paths for browser OAuth login.
# Defaults point to ignored local files under .yeeflow-oauth/.
# YEEFLOW_OAUTH_CALLBACK_CERT_FILE=.yeeflow-oauth/localhost-cert.pem
# YEEFLOW_OAUTH_CALLBACK_KEY_FILE=.yeeflow-oauth/localhost-key.pem

# Legacy/deprecated API-key fallback is not part of normal plugin/API use.
# Do not add API keys, tenant URLs, tenant IDs, API base URLs, or workspace IDs
# to normal `.env.local` setup.
